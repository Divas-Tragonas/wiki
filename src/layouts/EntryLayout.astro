---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '../components/TagBadge.astro';

interface Props {
  title: string;
  description?: string;
  breadcrumbs: { label: string; href: string }[];
  metadata?: { label: string; value: string }[];
  tags?: string[];
  showImage?: boolean;
  image?: string;
}

const { title, description, breadcrumbs, metadata = [], tags = [], showImage = false, image } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <div class="entry-container">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {breadcrumbs.map((crumb, i) => (
        <span class="crumb-item">
          {i > 0 && <span class="crumb-sep">›</span>}
          {i < breadcrumbs.length - 1 ? (
            <a href={`${base}${crumb.href}`} class="crumb-link">{crumb.label}</a>
          ) : (
            <span class="crumb-current">{crumb.label}</span>
          )}
        </span>
      ))}
    </nav>

    <div class="entry-layout">
      <!-- Main content -->
      <article class="entry-main">
        <h1 class="entry-title">{title}</h1>
        {description && <p class="entry-desc">{description}</p>}
        <div class="prose">
          <slot />
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="entry-sidebar">
        {showImage && (
          <div class="sidebar-card image-card">
            {image ? (
              <img src={`${base}${image}`} alt={title} class="entry-image" />
            ) : (
              <div class="entry-image-placeholder">
                <span class="placeholder-initial">{title.charAt(0)}</span>
              </div>
            )}
          </div>
        )}
        {metadata.length > 0 && (
          <div class="sidebar-card">
            <h4 class="sidebar-title">Informació</h4>
            <dl class="meta-list">
              {metadata.map(item => (
                <>
                  <dt class="meta-label">{item.label}</dt>
                  <dd class="meta-value">{item.value}</dd>
                </>
              ))}
            </dl>
          </div>
        )}
        {tags.length > 0 && (
          <div class="sidebar-card">
            <h4 class="sidebar-title">Etiquetes</h4>
            <div class="tags-list">
              {tags.map(tag => <TagBadge tag={tag} />)}
            </div>
          </div>
        )}
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .entry-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 2rem;
    font-size: 0.875rem;
  }
  .crumb-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .crumb-sep {
    color: #c9a84c;
    opacity: 0.5;
  }
  .crumb-link {
    color: #c9a84c;
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .crumb-link:hover { opacity: 1; }
  .crumb-current {
    color: #d4c9a8;
  }
  .entry-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .entry-layout {
      grid-template-columns: 1fr;
    }
    .entry-sidebar {
      order: -1;
    }
  }
  .entry-title {
    font-family: 'Cinzel', serif;
    font-size: 2rem;
    color: #e8c56a;
    margin: 0 0 0.75rem 0;
    line-height: 1.2;
  }
  .entry-desc {
    color: #d4c9a8;
    opacity: 0.7;
    font-size: 1.05rem;
    margin: 0 0 1.5rem 0;
    line-height: 1.6;
    border-left: 3px solid #c9a84c;
    padding-left: 1rem;
  }
  .sidebar-card {
    background-color: #1a1d24;
    border: 1px solid #252932;
    border-radius: 0.5rem;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  .sidebar-title {
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    color: #c9a84c;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.75rem 0;
  }
  .meta-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.375rem 0.75rem;
    font-size: 0.875rem;
  }
  .meta-label {
    color: #d4c9a8;
    opacity: 0.6;
  }
  .meta-value {
    color: #d4c9a8;
  }
  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .image-card {
    padding: 0;
    overflow: hidden;
  }
  .entry-image {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }
  .entry-image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 1;
    background-color: #14161c;
  }
  .placeholder-initial {
    font-family: 'Cinzel', serif;
    font-size: 3rem;
    color: #c9a84c;
    opacity: 0.35;
  }
</style>
