---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection } from 'astro:content';

const croniques = await getCollection('croniques');
const sorted = croniques.sort((a, b) => b.data.session - a.data.session);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Cròniques" description="Les cròniques de les sessions de La Mina Perduda de Phentanilo">
  <div class="page-container">
    <div class="page-header">
      <h1 class="page-title">Cròniques</h1>
      <p class="page-desc">El registre de les sessions de joc, en ordre cronològic invers.</p>
    </div>

    <div class="sessions-list">
      {sorted.map(session => (
        <a href={`${base}/croniques/${session.id}`} class="session-card">
          <div class="session-number">Sessió {session.data.session}</div>
          <div class="session-content">
            <h2 class="session-title">{session.data.title}</h2>
            <p class="session-summary">{session.data.summary}</p>
            <div class="session-meta">
              <span class="session-date">
                {new Date(session.data.date).toLocaleDateString('ca-ES', {
                  day: 'numeric',
                  month: 'long',
                  year: 'numeric',
                })}
              </span>
              <span class="session-players">
                {session.data.players.join(', ')}
              </span>
            </div>
            {session.data.tags.length > 0 && (
              <div class="session-tags">
                {session.data.tags.map(tag => <TagBadge tag={tag} />)}
              </div>
            )}
          </div>
          <span class="session-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 56rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  .page-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid #252932;
    padding-bottom: 1.25rem;
  }
  .page-title {
    font-family: 'Cinzel', serif;
    font-size: 2rem;
    color: #e8c56a;
    margin: 0 0 0.5rem 0;
  }
  .page-desc {
    color: #d4c9a8;
    opacity: 0.6;
    margin: 0;
  }
  .sessions-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .session-card {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 1.25rem;
    align-items: start;
    padding: 1.25rem;
    background-color: #1a1d24;
    border: 1px solid #252932;
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }
  .session-card:hover {
    border-color: #c9a84c;
    transform: translateX(4px);
  }
  .session-number {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #c9a84c;
    padding-top: 0.2rem;
    line-height: 1.4;
  }
  .session-title {
    font-family: 'Cinzel', serif;
    font-size: 1.1rem;
    color: #e8c56a;
    margin: 0 0 0.375rem 0;
  }
  .session-summary {
    font-size: 0.875rem;
    color: #d4c9a8;
    opacity: 0.75;
    margin: 0 0 0.75rem 0;
    line-height: 1.5;
  }
  .session-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: #d4c9a8;
    opacity: 0.5;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .session-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  .session-arrow {
    color: #c9a84c;
    opacity: 0.4;
    font-size: 1.125rem;
    padding-top: 0.125rem;
    transition: opacity 0.2s, transform 0.2s;
  }
  .session-card:hover .session-arrow {
    opacity: 1;
    transform: translateX(4px);
  }
</style>
