---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';
import { execFileSync } from 'node:child_process';

const croniques = await getCollection('croniques');
const characters = await getCollection('characters');
const places = await getCollection('places');

function getLastModified(filePath?: string): Date {
  if (!filePath) return new Date(0);
  try {
    const output = execFileSync('git', ['log', '-1', '--format=%cI', '--', filePath], {
      encoding: 'utf-8',
    }).trim();
    return output ? new Date(output) : new Date(0);
  } catch {
    return new Date(0);
  }
}

function latestBy<T>(entries: T[], dateOf: (entry: T) => Date): T {
  return entries.reduce((latest, entry) => (dateOf(entry) > dateOf(latest) ? entry : latest));
}

const latestSession = croniques.reduce((latest, c) => (c.data.session > latest.data.session ? c : latest));
const latestCharacter = latestBy(characters, (c) => getLastModified(c.filePath));
const latestPlace = latestBy(places, (p) => getLastModified(p.filePath));

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Inici" description="Wiki de la campanya D&D La Mina Perduda del Phentanilo">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">Campanya de D&D 5e</p>
      <h1 class="hero-title">La Mina Perduda del Phentanilo</h1>
      <p class="hero-tagline">
        Seguiu les aventures d'un grup d'aventurers que es fan un lloc a Phentanil,
        enfrontant-se a la Baina Roja i als perills que amaga la regió.
      </p>
      <div class="hero-buttons">
        <a href={`${base}/wiki`} class="btn-primary">Explorar la Wiki</a>
        <a href={`${base}/croniques`} class="btn-secondary">Llegir Cròniques</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-section">
    <div class="stats-inner">
      <div class="stat-item">
        <span class="stat-number">{characters.length}</span>
        <span class="stat-label">Personatges</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">{places.length}</span>
        <span class="stat-label">Llocs</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">{croniques.length}</span>
        <span class="stat-label">Sessions</span>
      </div>
    </div>
  </section>

  <!-- Latest changes -->
  <section class="recent-section">
    <div class="recent-inner">
      <div class="section-header">
        <h2 class="section-title">Últims Canvis</h2>
      </div>
      <div class="cards-grid">
        <Card
          title={`Sessió ${latestSession.data.session}: ${latestSession.data.title}`}
          description={latestSession.data.summary}
          href={`${base}/croniques/${latestSession.id}`}
          tags={latestSession.data.tags.slice(0, 3)}
          badge={new Date(latestSession.data.date).toLocaleDateString('ca-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
        />
        <Card
          title={latestCharacter.data.name}
          description={latestCharacter.data.description}
          href={`${base}/wiki/characters/${latestCharacter.id}`}
          tags={latestCharacter.data.tags}
        />
        <Card
          title={latestPlace.data.name}
          description={latestPlace.data.description}
          href={`${base}/wiki/places/${latestPlace.id}`}
          tags={latestPlace.data.tags}
          badge={latestPlace.data.type}
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(180deg, #0a0c10 0%, #0f1117 100%);
    border-bottom: 1px solid #252932;
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(201, 168, 76, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    max-width: 52rem;
    margin: 0 auto;
    position: relative;
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #c9a84c;
    margin: 0 0 1rem 0;
  }
  .hero-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    color: #e8c56a;
    margin: 0 0 1.25rem 0;
    line-height: 1.1;
    text-shadow: 0 0 60px rgba(232, 197, 106, 0.2);
  }
  .hero-tagline {
    font-size: 1.05rem;
    color: #d4c9a8;
    opacity: 0.75;
    max-width: 36rem;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }
  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    padding: 0.75rem 1.75rem;
    background-color: #c9a84c;
    color: #0a0c10;
    border-radius: 0.375rem;
    text-decoration: none;
    font-weight: 600;
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: background-color 0.2s;
  }
  .btn-primary:hover { background-color: #e8c56a; }
  .btn-secondary {
    padding: 0.75rem 1.75rem;
    background-color: transparent;
    color: #c9a84c;
    border: 1px solid #c9a84c;
    border-radius: 0.375rem;
    text-decoration: none;
    font-weight: 600;
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: background-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover {
    background-color: rgba(201, 168, 76, 0.1);
    color: #e8c56a;
  }
  .stats-section {
    background-color: #0a0c10;
    border-bottom: 1px solid #252932;
    padding: 1.5rem;
  }
  .stats-inner {
    max-width: 52rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
  }
  .stat-number {
    font-family: 'Cinzel', serif;
    font-size: 1.75rem;
    color: #e8c56a;
    font-weight: 700;
  }
  .stat-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #d4c9a8;
    opacity: 0.5;
  }
  .stat-divider {
    width: 1px;
    height: 2rem;
    background-color: #252932;
  }
  .recent-section {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  .section-title {
    font-family: 'Cinzel', serif;
    font-size: 1.375rem;
    color: #e8c56a;
    margin: 0;
  }
  .section-link {
    font-size: 0.875rem;
    color: #c9a84c;
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .section-link:hover { opacity: 1; }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 768px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>
