---
import EntryLayout from '../../../layouts/EntryLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const npcs = await getCollection('npcs');
  return npcs.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const statusLabel: Record<string, string> = {
  ally: 'Aliat',
  neutral: 'Neutral',
  unknown: 'Desconegut',
};

const base = import.meta.env.BASE_URL;
---

<EntryLayout
  title={entry.data.name}
  description={entry.data.description}
  breadcrumbs={[
    { label: 'Wiki', href: '/wiki' },
    { label: 'PNJs', href: '/wiki/npcs' },
    { label: entry.data.name, href: `/wiki/npcs/${entry.id}` },
  ]}
  metadata={[
    ...(entry.data.role ? [{ label: 'Rol', value: entry.data.role }] : []),
    { label: 'Estat', value: statusLabel[entry.data.status] },
  ]}
  tags={entry.data.tags}
  showImage={true}
  image={entry.data.image}
>
  <Content />
</EntryLayout>
