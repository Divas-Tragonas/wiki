---
import TagBadge from './TagBadge.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  tags?: string[];
  badge?: string;
  tone?: 'gold' | 'ally' | 'neutral' | 'enemy' | 'defeated';
}

const { title, description, href, tags = [], badge, tone = 'gold' } = Astro.props;
---

<a href={href} class="card-link">
  <div class="card">
    {badge && (
      <span class:list={['card-badge', `tone-${tone}`]}>{badge}</span>
    )}
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map(tag => <TagBadge tag={tag} />)}
      </div>
    )}
  </div>
</a>

<style>
  .card-link {
    text-decoration: none;
    color: inherit;
  }
  .card {
    background-color: #1a1d24;
    border: 1px solid #252932;
    border-radius: 0.5rem;
    padding: 1.25rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
    height: 100%;
    position: relative;
  }
  .card:hover {
    border-color: #c9a84c;
    transform: translateY(-2px);
  }
  .card-badge {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }
  .tone-gold {
    background-color: rgba(201, 168, 76, 0.2);
    color: #e8c56a;
    border: 1px solid rgba(201, 168, 76, 0.4);
  }
  .tone-ally {
    background-color: rgba(74, 158, 95, 0.2);
    color: #6fcf87;
    border: 1px solid rgba(74, 158, 95, 0.4);
  }
  .tone-neutral {
    background-color: rgba(150, 150, 170, 0.2);
    color: #b8b8cc;
    border: 1px solid rgba(150, 150, 170, 0.4);
  }
  .tone-enemy {
    background-color: rgba(201, 76, 76, 0.2);
    color: #e8807a;
    border: 1px solid rgba(201, 76, 76, 0.4);
  }
  .tone-defeated {
    background-color: rgba(120, 120, 130, 0.15);
    color: #8c8c98;
    border: 1px solid rgba(120, 120, 130, 0.35);
  }
  .card-title {
    font-family: 'Cinzel', serif;
    font-size: 1.125rem;
    color: #e8c56a;
    margin: 0 0 0.5rem 0;
  }
  .card-desc {
    font-size: 0.875rem;
    color: #d4c9a8;
    opacity: 0.8;
    margin: 0 0 0.75rem 0;
    line-height: 1.5;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
</style>
